---
import AdminLayout from '../layouts/AdminLayout.astro';
---
<AdminLayout title="System Overview">
  <div class="animate-slide-up">
    <!-- Title row -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12 mt-2">
      <div>
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 bg-clip-text text-transparent bg-gradient-to-r from-slate-900 via-indigo-900 to-slate-900">PBX Server Overview</h1>
        <p class="text-slate-500 mt-1 font-medium">Real-time monitoring and node management for IQFone Cluster.</p>
      </div>
      <div class="flex gap-3">
        <button class="px-6 py-3 bg-white border border-slate-200 text-slate-700 rounded-2xl text-sm font-bold hover:bg-slate-50 transition-all flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Export Report
        </button>
        <button class="px-6 py-3 bg-indigo-600 text-white rounded-2xl text-sm font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all flex items-center gap-2 group">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          Provision Number
        </button>
      </div>
    </div>

  <!-- Top Stat Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
    <!-- Card 1: Active Accounts -->
    <div class="group relative bg-white rounded-[2rem] p-8 border border-slate-100 hover:border-indigo-100 transition-all duration-300 hover:translate-y-[-4px]">
      <div class="absolute top-0 right-0 p-8">
        <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
        </div>
      </div>
      <div class="mb-8">
        <span class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">Subscriber Base</span>
        <h3 class="text-sm font-bold text-slate-900 mt-1">Active Accounts</h3>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-5xl font-bold tracking-tighter text-slate-900">426</span>
        <div class="flex flex-col">
          <span class="text-rose-500 font-bold text-xs flex items-center gap-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M14.707 12.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 14.586V3a1 1 0 012 0v11.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            12%
          </span>
          <span class="text-[10px] text-slate-400 font-medium">vs last month</span>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-slate-50 flex items-center justify-between">
        <div class="flex -space-x-2">
          {[1,2,3,4].map(i => <div class="w-6 h-6 rounded-full border-2 border-white bg-slate-100 flex items-center justify-center overflow-hidden"><img src={`https://i.pravatar.cc/100?img=${i+10}`} /></div>)}
          <div class="w-6 h-6 rounded-full border-2 border-white bg-indigo-50 text-indigo-600 text-[8px] font-bold flex items-center justify-center">+12</div>
        </div>
        <a href="/accounts" class="text-[10px] font-bold text-indigo-600 uppercase tracking-wider hover:underline">View All</a>
      </div>
    </div>
    
    <!-- Card 2: Extensions -->
    <div class="group relative bg-white rounded-[2rem] p-8 border border-slate-100 hover:border-sky-100 transition-all duration-300 hover:translate-y-[-4px]">
      <div class="absolute top-0 right-0 p-8">
        <div class="w-12 h-12 rounded-2xl bg-sky-50 text-sky-600 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </div>
      </div>
      <div class="mb-8">
        <span class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">Internal Nodes</span>
        <h3 class="text-sm font-bold text-slate-900 mt-1">Total Extensions</h3>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-5xl font-bold tracking-tighter text-slate-900">1,234</span>
        <div class="flex flex-col">
          <span class="text-emerald-500 font-bold text-xs flex items-center gap-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 5.414V17a1 1 0 11-2 0V5.414L6.707 7.707a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
            23%
          </span>
          <span class="text-[10px] text-slate-400 font-medium">high activity</span>
        </div>
      </div>
      <div class="mt-8">
        <div class="flex justify-between text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">
          <span>Usage Capacity</span>
          <span class="text-slate-900">68%</span>
        </div>
        <div class="w-full h-1.5 bg-slate-50 rounded-full overflow-hidden">
          <div class="h-full bg-sky-500 rounded-full" style="width: 68%"></div>
        </div>
      </div>
    </div>

    <!-- Card 3: Active Trunks -->
    <div class="group relative bg-indigo-600 rounded-[2rem] p-8 transition-all duration-300 hover:translate-y-[-4px] shadow-2xl shadow-indigo-200">
      <div class="absolute top-0 right-0 p-8">
        <div class="w-12 h-12 rounded-2xl bg-white/10 text-white flex items-center justify-center group-hover:rotate-12 transition-transform duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
        </div>
      </div>
      <div class="mb-8">
        <span class="text-white/50 font-bold uppercase tracking-widest text-[10px]">Infrastructure</span>
        <h3 class="text-sm font-bold text-white mt-1">Active Trunks</h3>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-5xl font-bold tracking-tighter text-white">102</span>
        <span class="px-2 py-0.5 bg-emerald-400 text-white text-[10px] font-bold rounded-full">HEALTHY</span>
      </div>
      <div class="mt-8 flex items-center gap-3">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-white/10 border-2 border-indigo-600 flex items-center justify-center text-white text-[10px] font-bold">T</div>
          <div class="w-8 h-8 rounded-full bg-white/10 border-2 border-indigo-600 flex items-center justify-center text-white text-[10px] font-bold">A</div>
          <div class="w-8 h-8 rounded-full bg-white/10 border-2 border-indigo-600 flex items-center justify-center text-white text-[10px] font-bold">V</div>
        </div>
        <span class="text-[10px] font-bold text-white/70 uppercase tracking-widest">3 Providers Online</span>
      </div>
    </div>
  </div>

  <!-- Bottom Cards Section -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <!-- Call Volume Chart (8 cols) -->
    <div class="lg:col-span-8 bg-white rounded-[2.5rem] p-10 border border-slate-100 flex flex-col">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-10">
        <div>
          <h2 class="text-2xl font-bold text-slate-900">Traffic Distribution</h2>
          <p class="text-sm text-slate-400 font-medium mt-1">Call volume distribution across internal and external networks.</p>
        </div>
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-indigo-500 shadow-lg shadow-indigo-200"></div>
            <span class="text-xs font-bold text-slate-600 uppercase tracking-wider">Inbound</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-rose-500 shadow-lg shadow-rose-200"></div>
            <span class="text-xs font-bold text-slate-600 uppercase tracking-wider">Outbound</span>
          </div>
        </div>
      </div>
      
      <div class="flex-1 min-h-[300px] flex items-end gap-4 sm:gap-8 pb-4">
        {[85, 45, 65, 95, 35, 75, 55, 90, 40, 60, 80, 50].map((h, i) => (
          <div class="flex-1 flex flex-col items-center group cursor-pointer h-full justify-end">
            <div class="w-full relative group">
               <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-slate-900 text-white text-[10px] font-bold rounded-lg opacity-0 group-hover:opacity-100 transition-all pointer-events-none">{h}k</div>
               <div class="w-full bg-slate-50 rounded-t-xl overflow-hidden transition-all duration-500 group-hover:bg-slate-100" style={`height: ${h}%`}>
                 <div class={`w-full h-full ${i % 3 === 0 ? 'bg-indigo-500' : i % 3 === 1 ? 'bg-rose-500' : 'bg-sky-500'} opacity-80 group-hover:opacity-100 transition-all`}></div>
               </div>
            </div>
            <span class="text-[10px] font-bold text-slate-400 mt-4 uppercase tracking-widest">{['J','F','M','A','M','J','J','A','S','O','N','D'][i]}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- System Health (4 cols) -->
    <div class="lg:col-span-4 bg-slate-900 rounded-[2.5rem] p-10 flex flex-col text-white overflow-hidden relative">
      <!-- Decorative Glow -->
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/20 rounded-full blur-[80px]"></div>
      
      <div class="relative z-10">
        <h2 class="text-2xl font-bold mb-8">System Health</h2>
        
        <div class="flex flex-col items-center mb-12">
          <div class="relative w-48 h-48 flex items-center justify-center">
            <svg viewBox="0 0 100 100" class="w-full h-full transform -rotate-90">
              <circle cx="50" cy="50" r="42" fill="transparent" stroke="rgba(255,255,255,0.05)" stroke-width="8"></circle>
              <circle cx="50" cy="50" r="42" fill="transparent" stroke="#6366f1" stroke-width="8" stroke-dasharray="264" stroke-dashoffset="66" stroke-linecap="round" class="drop-shadow-[0_0_8px_rgba(99,102,241,0.5)]"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-4xl font-bold tracking-tighter">98.2%</span>
              <span class="text-[10px] font-bold text-white/40 uppercase tracking-widest mt-1">Uptime</span>
            </div>
          </div>
        </div>

        <div class="space-y-8">
          <div>
            <div class="flex justify-between items-center mb-3">
              <span class="text-xs font-bold text-white/60 uppercase tracking-widest">Kamailio Core</span>
              <span class="text-xs font-bold text-emerald-400">OPTIMAL</span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-indigo-500 rounded-full w-[85%]" style="box-shadow: 0 0 10px rgba(99,102,241,0.3)"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between items-center mb-3">
              <span class="text-xs font-bold text-white/60 uppercase tracking-widest">FreeSWITCH Media</span>
              <span class="text-xs font-bold text-emerald-400">ACTIVE</span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-rose-500 rounded-full w-[42%]" style="box-shadow: 0 0 10px rgba(244,63,94,0.3)"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between items-center mb-3">
              <span class="text-xs font-bold text-white/60 uppercase tracking-widest">Redis Replication</span>
              <span class="text-xs font-bold text-sky-400">SYNCING</span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-sky-500 rounded-full w-[76%]" style="box-shadow: 0 0 10px rgba(14,165,233,0.3)"></div>
            </div>
          </div>
        </div>
        
        <button class="w-full mt-10 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl text-xs font-bold uppercase tracking-widest transition-all">
          View Service Logs
        </button>
      </div>
    </div>
  </div>

  <!-- Latency Section -->
  <div class="mt-12 bg-white rounded-[2.5rem] p-10 border border-slate-100">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Network Latency Matrix</h2>
        <p class="text-sm text-slate-400 font-medium mt-1">End-to-end latency and jitter analysis across global regions.</p>
      </div>
      <div class="p-1 bg-slate-50 rounded-xl border border-slate-100 flex gap-1">
        <button class="px-4 py-2 bg-white text-indigo-600 text-xs font-bold rounded-lg shadow-sm border border-slate-200/50">24 Hours</button>
        <button class="px-4 py-2 text-slate-400 hover:text-slate-600 text-xs font-bold rounded-lg transition-colors">7 Days</button>
        <button class="px-4 py-2 text-slate-400 hover:text-slate-600 text-xs font-bold rounded-lg transition-colors">30 Days</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { region: 'North America', lat: '12ms', jit: '1ms', status: 'optimal' },
        { region: 'Europe West', lat: '84ms', jit: '4ms', status: 'good' },
        { region: 'Asia Pacific', lat: '162ms', jit: '12ms', status: 'warning' },
        { region: 'South America', lat: '95ms', jit: '3ms', status: 'good' }
      ].map(r => (
        <div class="p-6 rounded-[2rem] bg-slate-50/50 border border-slate-100 hover:border-indigo-100 transition-all group">
          <div class="flex justify-between items-start mb-6">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">{r.region}</span>
            <div class={`w-2 h-2 rounded-full ${r.status === 'optimal' ? 'bg-emerald-500' : r.status === 'good' ? 'bg-sky-500' : 'bg-amber-500'} animate-pulse`}></div>
          </div>
          <div class="space-y-4">
            <div class="flex justify-between items-end">
              <span class="text-xs font-bold text-slate-500">Latency</span>
              <span class="text-2xl font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">{r.lat}</span>
            </div>
            <div class="flex justify-between items-end">
              <span class="text-xs font-bold text-slate-500">Jitter</span>
              <span class="text-sm font-bold text-slate-700">{r.jit}</span>
            </div>
            <div class="w-full h-1 bg-slate-200 rounded-full overflow-hidden">
               <div class={`h-full ${r.status === 'optimal' ? 'bg-emerald-500' : r.status === 'good' ? 'bg-sky-500' : 'bg-amber-500'}`} style={`width: ${r.status === 'optimal' ? '90%' : '70%'}`}></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  </div>
</AdminLayout>